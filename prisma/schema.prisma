generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id          String          @id @default(uuid())
  name        String
  department  String
  tierLimit   Float
  address     String          @default("Not Provided")
  designation String          @default("Not Specified")
  rating      Float           @default(100)
  expenses    Expense[]
  payouts     MonthlyPayout[]
}

model Expense {
  id         String   @id @default(uuid())
  employeeId String
  merchant   String
  amount     Float
  currency   String   @default("INR")
  timestamp  DateTime
  category   String
  lineItems  Json
  createdAt  DateTime @default(now())
  audit      Audit?
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Audit {
  id                      String    @id @default(uuid())
  expenseId               String    @unique
  calculatedReimbursement Float
  riskScore               Int
  status                  String
  anomalies               Anomaly[]
  expense                 Expense   @relation(fields: [expenseId], references: [id], onDelete: Cascade)
}

model Anomaly {
  id          String @id @default(uuid())
  auditId     String
  type        String
  description String
  severity    String
  audit       Audit  @relation(fields: [auditId], references: [id], onDelete: Cascade)
}

model MonthlyPayout {
  id                  String    @id @default(uuid())
  employeeId          String
  year                Int
  month               Int
  totalClaimed        Float
  totalReimbursement  Float
  categoryBreakdown   Json
  expenseCount        Int
  status              String    @default("PENDING")
  closedAt            DateTime  @default(now())
  paidAt              DateTime?

  employee            Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, year, month])
}
